<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.douyu.glowsticks</string>
    <key>ProgramArguments</key>
    <array>
        <string>/path/to/your/project/douyu-gift</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>0</integer>
        <key>Minute</key>
        <integer>5</integer>
    </dict>
    <key>WorkingDirectory</key>
    <string>/path/to/your/project</string>
    <key>StandardOutPath</key>
    <string>/path/to/your/project/stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/your/project/stderr.log</string>
</dict>
</plist>
